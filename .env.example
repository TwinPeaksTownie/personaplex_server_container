# Hugging Face Token (Required)
# Get yours at: https://huggingface.co/settings/tokens
# Accept the PersonaPlex license: https://huggingface.co/nvidia/personaplex-7b-v1
HF_TOKEN=your_huggingface_token_here

# Backend API URL (for frontend)
VITE_QUEUE_API_URL=http://personaplex-backend:8080

# Optional: Disable torch compilation for faster startup
NO_TORCH_COMPILE=1
